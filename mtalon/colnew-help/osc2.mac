/* The quantum harmonic oscillator, for state n=6. It is numerically hard
and requires to increase the number of collocation points per interval and
the number of initial subintervals. */

L:10.0$ aleft:0$ aright:L$ ntol:3$
depends([p,e],x)$ lvfs:[x,p,e]$
list_of_eqns:[diff(p,x,2)=x^2*p-2.0*e*p,diff(e,x,1)=0]$
list_of_conds:[(p-1)(0)=0,diff(p,x,1)(0)=0,p(L)=0]$
list_of_guess:[(1.0-x^4)*exp(-x^2/2),7.0]$ /* guess for p and for e */

load("colnew_help.mac")$

/* With guess [(1.0+x^6)*exp(-x^2/2),7.0] 
set ipar:[1,4,5,3,8000,500,1,0,1,0,0]$
at the break point or the result is wrong.
Also set tol:[1d-6,1d-6,1d-6]$ */

xx:makelist(L/100*k,k,0,99)$

use_result():= (
  zvals: colnew_appsln(xx, mstar, fspace, ispace),
  hvals:makelist(zvals[k][1],k,1,100))$

run_colnew()$

ratprint:false$
exact:makelist(float(ratsubst(0.1*k,x,hermite(6,x)))/(-120)*exp(-(0.1*k)^2/2),k,0,99)$
print(" e = ", zvals[1][3])$

plot2d([[discrete,xx,hvals],[discrete,xx,exact]],[style, points, lines],
  [point_type,plus],[legend,"colnew","hermite"])$


